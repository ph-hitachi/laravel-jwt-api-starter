// Laravel JWT API Starter API — Database Schema
// Render at: https://dbdiagram.io
// Copy & paste the entire content below into the editor

Table user_settings {
  id                 bigint        [pk, increment, not null]
  user_id            bigint        [not null, ref: > users.id]
  key                varchar(255)  [not null]
  value              text          [not null]
  created_at         timestamp     [null]
  updated_at         timestamp     [null]

  indexes {
    (user_id, key) [unique]
  }
}

Table users {
  id                 bigint        [pk, increment, not null]
  name               varchar(255)  [not null]
  username           varchar(255)  [unique, null]
  email              varchar(255)  [unique, not null]
  avatar_url         varchar(255)  [null]
  google_id          bigint        [unique, null]
  facebook_id        bigint        [unique, null]
  email_verified_at  timestamp     [null]
  password           varchar(255)  [null]
  phone_number       varchar(255)  [null]
  phone_iso_code     varchar(255)  [null]
  phone_dial_code    varchar(255)  [null]
  role               enum          [not null, default: "user", note: "user | admin"]
  is_active          boolean       [not null, default: true]
  remember_token     varchar(255)  [null]
  created_at         timestamp     [null]
  updated_at         timestamp     [null]

  indexes {
    email [unique]
  }
}

